# Bytez API key (LLM + embeddings)
VITE_BYTEZ_API_KEY="YOUR_BYTEZ_API_KEY"

# Bytez API base URL (optional)
VITE_BYTEZ_BASE_URL="https://api.bytez.com/v1"

# Default Bytez chat model (optional)
VITE_BYTEZ_CHAT_MODEL="Qwen/Qwen2-7B-Instruct"

# Bytez embeddings model (optional)
VITE_BYTEZ_EMBED_MODEL="BAAI/bge-large-en-v1.5"

# Embedding dimensions (optional, 768 recommended for current DB setup)
VITE_BYTEZ_EMBED_DIMENSIONS="768"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase — récupérer depuis https://app.supabase.com → Settings → API
VITE_SUPABASE_URL="https://xxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJxxx"

# Viva Wallet — https://developer.vivawallet.com (sandbox pour tests)
VITE_VIVA_WALLET_BASE_URL="https://demo.vivapayments.com"
VITE_VIVA_CLIENT_ID="placeholder"
VITE_VIVA_CLIENT_SECRET="placeholder"
VIVA_MERCHANT_ID="placeholder"
VIVA_API_KEY="placeholder"
