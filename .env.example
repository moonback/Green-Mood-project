# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Gemini Live API — (ancien moteur vocal, conservé pour rollback)
# Obtenir une clé sur https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ElevenLabs Conversational AI — nouveau moteur vocal (remplace Gemini Live)
# 1. Créer un Agent sur https://elevenlabs.io/app/conversational-ai
# 2. LLM recommandé : Claude 3.5 Sonnet | Langue : fr | Agent public
# 3. Ajouter les 5 Client Tools : search_catalog, add_to_cart, view_product, navigate_to, close_session
#    (search_catalog, add_to_cart, view_product, navigate_to → "Wait for response" activé)
# 4. Copier l'Agent ID ci-dessous
VITE_ELEVENLABS_AGENT_ID="YOUR_AGENT_ID"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"


# OpenRouter — embeddings & LLM (https://openrouter.ai/keys)
VITE_OPENROUTER_API_KEY="sk-or-..."
# Modèle d'embedding (optionnel)
VITE_OPENROUTER_EMBED_MODEL="openai/text-embedding-3-small"
# Dimensions de sortie (optionnel, 768 recommandé pour la base actuelle)
VITE_OPENROUTER_EMBED_DIMENSIONS="768"

# Supabase — récupérer depuis https://app.supabase.com → Settings → API
VITE_SUPABASE_URL="https://xxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJxxx"

# Viva Wallet — https://developer.vivawallet.com (sandbox pour tests)
VITE_VIVA_WALLET_BASE_URL="https://demo.vivapayments.com"
VITE_VIVA_CLIENT_ID="placeholder"
VITE_VIVA_CLIENT_SECRET="placeholder"
VIVA_MERCHANT_ID="placeholder"
VIVA_API_KEY="placeholder"
